PORT=3000

# Облако (Render и т.п.): вставь External Database URL
# DATABASE_URL=postgresql://user:pass@host.region-postgres.render.com/dbname

# Локальный PostgreSQL без URL:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_NAME=auth_demo

# Для DATABASE_URL: по умолчанию SSL с rejectUnauthorized: false (нужно для Render).
# DB_SSL=false
